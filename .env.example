# 복사: cp .env.example .env 후 값 입력. Metro 재시작 필요.

# 앱이 바라볼 Signal API 서버(번들 기본값). 비워도 되며, 그 경우 앱 설정 → 표시 → Signal 서버에서
# 개발/리얼/커스텀을 고르면 됩니다. 값이 있으면 「빌드(.env)」 모드의 기본 URL로 쓰입니다.
# 로컬 서버 예: http://127.0.0.1:4000
EXPO_PUBLIC_SIGNAL_API_BASE_URL=http://127.0.0.1:4000

# 선택: AdMob 광고 단위 ID (비우면 Google 테스트 광고 — 네이티브 빌드만)
# EXPO_PUBLIC_ADMOB_NATIVE_UNIT_ID=
# EXPO_PUBLIC_ADMOB_BANNER_UNIT_ID=

# 개발 전용: OTA 배너 UI만 화면에 띄워 확인 (__DEV__). 켜짐: 1 / true / yes — 끔: 0 / false / 삭제
# EXPO_PUBLIC_PREVIEW_OTA_BANNER=1
