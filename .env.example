# 복사: cp .env.example .env 후 값 입력. Metro 재시작 필요.

# 필수: 글로벌 뉴스 + 실적/경제 캘린더 (https://finnhub.io)
EXPO_PUBLIC_FINNHUB_TOKEN=

# 권장: 한국어 3줄 요약 · 유튜브 메타 요약 · 컨콜 요약 (https://console.anthropic.com)
EXPO_PUBLIC_ANTHROPIC_API_KEY=

# 경제 유튜브 검색 (https://console.cloud.google.com → YouTube Data API v3 활성화)
EXPO_PUBLIC_YOUTUBE_API_KEY=

# 선택: 실적콜 트랜스크립트 (https://api-ninjas.com)
EXPO_PUBLIC_API_NINJAS_KEY=

# 선택: AdMob 광고 단위 ID (비우면 Google 테스트 광고 — 네이티브 빌드만)
# EXPO_PUBLIC_ADMOB_NATIVE_UNIT_ID=
# EXPO_PUBLIC_ADMOB_BANNER_UNIT_ID=
