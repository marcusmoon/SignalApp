# Local Signal API server
PORT=4000
HOST=127.0.0.1

# Admin UI login (required): one-line JSON array.
ADMIN_USERS=[{"id":"dev","password":"change-me"}]
SESSION_SECRET=change-me-local-session-secret

# Optional seed/fallback values. Prefer Admin > Settings for local operation.
# FINNHUB_TOKEN=
# OPENAI_API_KEY=
# ANTHROPIC_API_KEY=
# YOUTUBE_API_KEY=
# NINJAS_KEY=

# Optional seed/fallback values. Prefer Admin > Translation Settings for local operation.
# Translation providers: mock | openai | claude
# OpenAI suggested starter model: gpt-4o-mini
# Claude suggested starter model: claude-3-5-haiku-latest
TRANSLATION_PROVIDER=mock
TRANSLATION_MODEL=mock-ko-news-v1
